NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

LLM_PROVIDER=openai
EMBEDDING_MODEL=all-MiniLM-L6-v2

TOKEN_BUDGET_DEFAULT=8000
TOKEN_BUDGET_MAX=16000

IMPACT_CONFIDENCE_THRESHOLD=0.1
IMPACT_MAX_DEPTH=5

RISK_WEIGHT_BLAST_RADIUS=0.25
RISK_WEIGHT_CRITICAL_PATH=0.20
RISK_WEIGHT_DATA_SENSITIVITY=0.20
RISK_WEIGHT_CHANGE_FREQUENCY=0.15
RISK_WEIGHT_COUPLING=0.10
RISK_WEIGHT_TEST_COVERAGE=0.10
